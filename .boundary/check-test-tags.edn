 ["libs/e2e/"
  "libs/tools/"
  "libs/jobs/"
  "libs/cache/"
  "libs/boundary-cli/"
  "libs/devtools/"
  "libs/storage/"
  "libs/scaffolder/"
  "libs/reports/"
  "libs/ui-style/"
  "libs/audience/"
  "libs/ai/"
  "test/"]}
