{:users
 {:label           "Users"
  ;; Keep the list view compact but include the most important identity fields.
  :list-fields     [:email :name :role :active :created-at]
  :search-fields   [:email :name]
  ;; Hide sensitive and internal fields in admin UI.
  :hide-fields     #{:password-hash
                     :mfa-secret
                     :mfa-backup-codes
                     :mfa-backup-codes-used
                     :deleted-at}
  ;; UPDATE targets the users (profile) table for primary fields.
  ;; email and active live in auth_users and are routed there via :split-table-update.
  ;; mfa-enabled is controlled by the MFA enrollment flow, not the generic edit form.
  :table-name      :users
  :readonly-fields #{:id :mfa-enabled :created-at :updated-at}

  ;; Split-table update: fields listed under :secondary-fields are written to
  ;; :secondary-table instead of the primary :table-name.  Both UPDATEs run in
  ;; a single transaction so they commit or roll back atomically.
  :split-table-update {:secondary-table :auth_users
                       :secondary-fields #{:email :active}}

  ;; Field filter config — drives the "Add filter" dropdown in the admin list view.
  ;; Fields not listed here (e.g. :email, :name) are covered by the free-text search.
  :fields
  {:email      {:filterable false}   ; covered by free-text search
   :name       {:filterable false}   ; covered by free-text search
   :role       {:type :enum    :label "Role"
                :options [[:admin "Admin"] [:user "User"] [:viewer "Viewer"]]
                :filterable true}
   :active     {:type :boolean :label "Active"  :filterable true}
   :created-at {:type :instant :label "Created" :filterable true}}

  ;; Field ordering - fields appear in this order, others follow
  :field-order     [:email
                    :name
                    :role
                    :active
                    :theme
                    :language
                    :timezone
                    :date-format
                    :time-format
                    :notifications-email
                    :notifications-push
                    :notifications-sms
                    :created-at
                    :updated-at]

  ;; Field grouping - organize form fields into sections
  :field-groups
  [{:id :identity     :label "Identity"     :fields [:email :name]}
   {:id :access       :label "Access"       :fields [:role :active]}
   {:id :preferences  :label "Preferences"  :fields [:theme
                                                     :language
                                                     :timezone
                                                     :date-format
                                                     :time-format]}
   {:id :notifications :label "Notifications" :fields [:notifications-email
                                                       :notifications-push
                                                       :notifications-sms]}]

  ;; Multi-table JOIN: email lives in auth_users, profile fields in users
  :query-overrides
  {:from             [[:auth_users :a]]
   :join             [[:users :u] [:= :a.id :u.id]]
   :select           [:a.id :a.email :a.active :a.mfa_enabled
                      :a.created_at :a.updated_at :a.deleted_at
                      :u.name :u.role :u.tenant_id :u.avatar_url
                      :u.login_count :u.last_login
                      :u.notifications_email :u.notifications_push :u.notifications_sms
                      :u.theme :u.language :u.timezone :u.date_format :u.time_format]
   :field-aliases    {:id         :a.id
                      :email      :a.email
                      :active     :a.active
                      :deleted-at :a.deleted_at
                      :created-at :a.created_at
                      :name       :u.name
                      :role       :u.role}
   :soft-delete-table :auth_users}}}
