{ ;; =============================================================================
 ;; Acceptance (ACC) Environment Configuration
 ;; =============================================================================

 :active
 {  ;; Core application settings (always active)
  :boundary/settings
  {:name              "boundary-acc"
   :secure-cookies? true  ;; HTTPS-only auth cookies
   :version           "0.1.0"
   :date-format       "yyyy-MM-dd"
   :date-time-format  "yyyy-MM-dd HH:mm:ss"
   :currency/iso-code "EUR"}

  ;; Database configuration (typically PostgreSQL in acceptance)
  :boundary/postgresql
  {:host          #env "POSTGRES_HOST"
   :port          #env "POSTGRES_PORT"
   :dbname        #env "POSTGRES_DB"
   :user          #env "POSTGRES_USER"
   :password      #env "POSTGRES_PASSWORD"
   :auto-commit   true
   :pool          {:minimum-idle 5
                   :maximum-pool-size 20
                   :connection-timeout-ms 30000
                   :idle-timeout-ms 600000
                   :max-lifetime-ms 1800000
                   :keepalive-time-ms 30000
                   :validation-timeout-ms 5000
                   :leak-detection-threshold-ms 60000}}

  ;; Acceptance logging configuration
  :boundary/logging
  {:level     :info
   :console   false
   :appenders [{:appender       :rolling-file
                :file           "logs/boundary-acc.log"
                :rolling-policy {:type        :time-based
                                 :max-history 30
                                 :max-size    20000000
                                 :pattern     ".%d{yyyy-MM-dd}.%i.gz"}}]}

  ;; HTTP server — CSRF enforcement explicitly ON for acc (lib default is opt-in/off).
  ;; Secret must come from the environment; no literal fallback. The wiring guard throws
  ;; at startup if enabled with a blank secret, so the app refuses to boot rather than
  ;; fail open (run unvalidated). Set JWT_SECRET in the environment.
  :boundary/http
  {;; Graceful shutdown drain window (ms): stop accepting new connections, let
   ;; in-flight requests finish (up to this bound), then halt. Tune to exceed
   ;; the load balancer's deregistration delay for zero-downtime rollouts.
   :drain-timeout-ms #long #or [#env HTTP_DRAIN_TIMEOUT_MS 30000]
   ;; Per-client rate limiting (fixed window). Disabled by default: enable it only
   ;; together with an active :boundary/cache (Redis) so the limit is shared across
   ;; replicas. Without an active cache the limiter falls back to a bounded
   ;; per-process counter — each instance counts independently (effective limit =
   ;; limit x N), so do NOT rely on it as a global limit in a multi-replica
   ;; deployment. Enable via HTTP_RATE_LIMIT_ENABLED=true once Redis is active.
   :rate-limit {:enabled?  #boolean #or [#env HTTP_RATE_LIMIT_ENABLED "false"]
                :limit     #long #or [#env HTTP_RATE_LIMIT 300]
                :window-ms #long #or [#env HTTP_RATE_LIMIT_WINDOW_MS 60000]}
   :security {:csrf {:enabled? true
                     :secret   #or [#env CSRF_SECRET #env JWT_SECRET]}}}

  ;; Acceptance error reporting configuration (Sentry)
  :boundary/error-reporting
  {:provider    :sentry
   :dsn         #env "SENTRY_DSN"
   :environment "acc"
   :release     #or [#env "APP_RELEASE" #env "VERSION"]
   :sample-rate 1.0}}

 :inactive
 {;; Cache configuration — move :boundary/cache to :active to enable Redis caching.
  ;; Requires a Redis instance.
  :boundary/cache
  {:provider    :redis
   :host        #env "REDIS_HOST"
   :port        #or [#long #or [#env "REDIS_PORT" 6379] 6379]
   :password    #env "REDIS_PASSWORD"
   :database    0
   :timeout     2000
   :default-ttl 300
   :max-total   20
   :max-idle    10
   :min-idle    2}

  ;; Optional fallback database configurations
  :boundary/sqlite
  {:db "acc-fallback.db"
   :pool {:minimum-idle 1
          :maximum-pool-size 5
          :connection-timeout-ms 10000}}

  :boundary/h2
  {:memory false
   :db     "acc-h2-fallback"
   :pool   {:minimum-idle 1
            :maximum-pool-size 5}}}}
