{:users
 {:label           "Users"
  :list-fields     [:email :name :role :active :created-at]
  :search-fields   [:email :name]
  :hide-fields     #{:password-hash
                     :mfa-secret
                     :mfa-backup-codes
                     :mfa-backup-codes-used
                     :deleted-at}
  :readonly-fields #{:id :created-at :updated-at}

  :field-order     [:email
                    :name
                    :role
                    :active
                    :theme
                    :language
                    :timezone
                    :date-format
                    :time-format
                    :notifications-email
                    :notifications-push
                    :notifications-sms
                    :created-at
                    :updated-at]

  :field-groups
  [{:id :identity     :label "Identity"     :fields [:email :name]}
   {:id :access       :label "Access"       :fields [:role :active]}
   {:id :preferences  :label "Preferences"  :fields [:theme
                                                     :language
                                                     :timezone
                                                     :date-format
                                                     :time-format]}
   {:id :notifications :label "Notifications" :fields [:notifications-email
                                                       :notifications-push
                                                       :notifications-sms]}]

  ;; Multi-table JOIN: email lives in auth_users, profile fields in users
  :query-overrides
  {:from             [[:auth_users :a]]
   :join             [[:users :u] [:= :a.id :u.id]]
   :select           [:a.id :a.email :a.active :a.mfa_enabled
                      :a.created_at :a.updated_at :a.deleted_at
                      :u.name :u.role :u.tenant_id :u.avatar_url
                      :u.login_count :u.last_login
                      :u.notifications_email :u.notifications_push :u.notifications_sms
                      :u.theme :u.language :u.timezone :u.date_format :u.time_format]
   :field-aliases    {:id         :a.id
                      :email      :a.email
                      :active     :a.active
                      :deleted-at :a.deleted_at
                      :created-at :a.created_at
                      :name       :u.name
                      :role       :u.role}
   :soft-delete-table :auth_users}}}
