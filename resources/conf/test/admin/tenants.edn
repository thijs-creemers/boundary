{:tenants
 {:label       "Tenants"
  :description "Multi-tenant organizations"
  :icon        :building-2
  :table-name  :tenants
  :list-fields [:slug :name :status :created-at]
  :search-fields [:slug :name]
  :hide-fields #{:deleted-at}
  :readonly-fields #{:id :schema-name :created-at :updated-at}
  :fields
  {:slug       {:label [:t :admin.tenants/field-slug]}
   :name       {:label [:t :admin.tenants/field-name]}
   :status     {:type :enum
                :label [:t :admin.tenants/field-status]
                :options [[:active    [:t :admin.tenants/status-active]]
                          [:suspended [:t :admin.tenants/status-suspended]]
                          [:deleted   [:t :admin.tenants/status-deleted]]]
                :filterable true}
   :schema-name {:label [:t :admin.tenants/field-schema-name]}
   :settings    {:label [:t :admin.tenants/field-settings]}
   :created-at  {:type :instant :label [:t :admin.tenants/field-created] :filterable true}}
  :field-order [:slug :name :status :schema-name :settings :created-at :updated-at]
  :field-groups
  [{:id :identity :label [:t :admin.tenants/group-identity] :fields [:slug :name]}
   {:id :state    :label [:t :admin.tenants/group-state]    :fields [:status :schema-name]}
   {:id :config   :label [:t :admin.tenants/group-settings] :fields [:settings]}]}}
