# /etc/boundary/boundary.env
# Permissions: chmod 600, owned by root
# Referenced by boundary.service via EnvironmentFile=

# Required
BND_ENV=prod
JWT_SECRET=change-me-to-a-strong-secret-at-least-32-characters

# Database (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=boundary
POSTGRES_USER=boundary
POSTGRES_PASSWORD=change-me

# HTTP
HTTP_PORT=3000

# Optional: Error reporting
# SENTRY_DSN=https://key@sentry.io/project

# Optional: Redis (enable cache in config.edn first)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=change-me

# Optional: Payments
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: Email domain restrictions
# ALLOWED_EMAIL_DOMAIN=yourcompany.com
# ADMIN_EMAIL_DOMAIN=yourcompany.com
