{:paths ["src"]

 :deps  {org.clojure/clojure                {:mvn/version "1.12.5"}

         ;; Boundary core — pulled straight from this repository via :local/root,
         ;; so the example runs against the checked-out source with no publish
         ;; step. In a real project you would use the published coordinate:
         ;;   org.boundary-app/boundary-core {:mvn/version "1.0.0-beta-1"}
         org.boundary-app/boundary-core    {:local/root "../../libs/core"}

         ;; H2 (in-memory) + next.jdbc for the persistence shell.
         com.github.seancorfield/next.jdbc {:mvn/version "1.3.1108"}
         com.h2database/h2                 {:mvn/version "2.4.240"}}

 :aliases
 {:run {:main-opts ["-m" "todo.main"]}}}
