{:server {:port 3002
          :join? false}

 :database {:dbtype "sqlite"
            :dbname "ecommerce-dev.db"}

 ;; Boundary db-context (second pool to same SQLite — used by user + admin modules)
 :db-context {:adapter       :sqlite
              :database-path "ecommerce-dev.db"}

 ;; Admin UI
 :boundary/admin
 {:enabled?         true
  :base-path        "/web/admin"
  :require-role     :admin
  :entity-discovery {:mode      :allowlist
                     :allowlist #{:products :orders :users}}
  :entities         #merge [#include "admin/products.edn"
                            #include "admin/orders.edn"
                            #include "admin/users.edn"]
  :pagination       {:default-page-size 20
                     :max-page-size     200}}

 ;; User module config
 :user {:validation {:password-min-length 8
                     :require-uppercase   false
                     :require-digits      false}}

 :payment {:provider :mock
           :webhook-secret "whsec_test_secret_for_development"
           ;; In production, this would be real Stripe keys
           :api-key "sk_test_mock_key"}}
