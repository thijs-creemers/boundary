{;; =============================================================================
 ;; Ecommerce API — dev configuration
 ;;
 ;; Loaded by the app (system.clj) and by `bb create-admin --dir examples/ecommerce-api`.
 ;; =============================================================================

 :active
 {:server {:port 3002 :join? false}

  ;; HikariCP datasource (ecommerce repositories)
  :database {:dbtype "sqlite" :dbname "ecommerce-dev.db"}

  ;; Boundary db-context (user + admin modules)
  :db-context {:adapter :sqlite :database-path "ecommerce-dev.db"}

  ;; Boundary CLI db connection — used by `bb create-admin`
  :boundary/sqlite
  {:db   "ecommerce-dev.db"
   :pool {:minimum-idle          1
          :maximum-pool-size     3
          :connection-timeout-ms 10000}}

  ;; Boundary settings — used by `bb create-admin` + user module
  :boundary/settings
  {:user-validation
   {:password-policy   {:min-length             8
                        :max-length             128
                        :require-uppercase?     false
                        :require-lowercase?     false
                        :require-numbers?       false
                        :require-special-chars? false
                        :forbidden-patterns     #{}}
    :name-restrictions {:min-length 1 :max-length 100}
    :role-restrictions {:allowed-roles       #{:user :admin}
                        :admin-email-domains #{}
                        :default-role        :user}
    :user-limits       {:max-users      10000
                        :check-enabled? false}}}

  ;; Admin UI
  :boundary/admin
  {:enabled?         true
   :base-path        "/web/admin"
   :require-role     :admin
   :entity-discovery {:mode      :allowlist
                      :allowlist #{:products :orders :order-items :users}}
   :entities         #merge [#include "../admin/products.edn"
                             #include "../admin/orders.edn"
                             #include "../admin/order-items.edn"
                             #include "../admin/users.edn"]
   :pagination       {:default-page-size 20
                      :max-page-size     200}}

  ;; User module
  :user {:validation {:password-min-length 8
                      :require-uppercase   false
                      :require-digits      false}}

  ;; Payment provider
  :payment {:provider       :mock
            :webhook-secret "whsec_test_secret_for_development"
            :api-key        "sk_test_mock_key"}}

 :inactive {}}
