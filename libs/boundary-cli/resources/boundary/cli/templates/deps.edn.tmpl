{:paths ["src" "resources"]
 :deps  {org.boundary-app/boundary-core         {:mvn/version "{{core-version}}"}
         org.boundary-app/boundary-observability {:mvn/version "{{observability-version}}"}
         org.boundary-app/boundary-platform      {:mvn/version "{{platform-version}}"}
         org.boundary-app/boundary-user          {:mvn/version "{{user-version}}"}
         ;; Required by boundary-platform's system wiring (unconditional module loads)
         org.boundary-app/boundary-cache         {:mvn/version "{{cache-version}}"}
         org.boundary-app/boundary-admin         {:mvn/version "{{admin-version}}"}
         org.boundary-app/boundary-tenant        {:mvn/version "{{tenant-version}}"}
         org.boundary-app/boundary-workflow      {:mvn/version "{{workflow-version}}"}
         org.boundary-app/boundary-search        {:mvn/version "{{search-version}}"}
         org.boundary-app/boundary-external      {:mvn/version "{{external-version}}"}
         org.boundary-app/boundary-payments      {:mvn/version "{{payments-version}}"}
         org.boundary-app/boundary-i18n          {:mvn/version "{{i18n-version}}"}
         com.h2database/h2                       {:mvn/version "2.4.240"}}
 :aliases
 {:repl-clj {:extra-paths ["dev"]
             :extra-deps {nrepl/nrepl {:mvn/version "1.3.0"}
                          cider/cider-nrepl {:mvn/version "0.50.2"}}
             :main-opts  ["-m" "nrepl.cmdline" "--middleware" "[cider.nrepl/cider-middleware]"
                          "--port" "7888"]}
  :test     {:extra-paths ["test"]
             :extra-deps  {lambdaisland/kaocha {:mvn/version "1.91.1392"}}
             :main-opts   ["-m" "kaocha.runner"]}
  :migrate  {:main-opts ["-m" "boundary.platform.shell.database.cli-migrations"]}}}
