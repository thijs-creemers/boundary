;; deps.edn
{:paths   ["src" "test" "resources"                         ;; Monolith paths
           "libs/core/src" "libs/core/test"                 ;; Phase 1: Core library
           "libs/observability/src" "libs/observability/test" ;; Phase 2: Observability
           "libs/platform/src" "libs/platform/test"         ;; Phase 3: Platform
           "libs/user/src" "libs/user/test"                 ;; Phase 4: User
           "libs/admin/src" "libs/admin/test"               ;; Phase 5: Admin
           "libs/storage/src" "libs/storage/test"           ;; Phase 6: Storage
           "libs/scaffolder/src" "libs/scaffolder/test"     ;; Phase 8: Scaffolder
           "libs/cache/src" "libs/cache/test"               ;; Phase 9: Cache
           "libs/jobs/src" "libs/jobs/test"                 ;; Phase 10: Jobs
           "libs/email/src" "libs/email/test"               ;; Phase 11: Email
           "libs/tenant/src" "libs/tenant/test"             ;; Phase 7: Tenant
           "libs/realtime/src" "libs/realtime/test"         ;; Phase 12: Realtime
           "libs/payments/src" "libs/payments/test"         ;; Payments: PSP abstraction
           "libs/external/src" "libs/external/test"         ;; Phase 13: External
           "libs/workflow/src" "libs/workflow/test"         ;; Phase 14: Workflow
           "libs/search/src" "libs/search/test"             ;; Phase 15: Search
           "libs/reports/src" "libs/reports/test"           ;; Phase 16: Reports
           "libs/calendar/src" "libs/calendar/test"         ;; Phase 17: Calendar
           "libs/geo/src" "libs/geo/test"                   ;; Phase 18: Geo
           "libs/geo/resources"
           "libs/ai/src" "libs/ai/test"                     ;; Phase 19: AI
           "libs/ui-style/src"                              ;; Shared UI style API
           "libs/ui-style/resources"                        ;; Shared UI assets (CSS/JS/Tailwind)
           "libs/i18n/src" "libs/i18n/test"                 ;; Phase 20: Internationalisation
           "libs/i18n/resources"]                            ;; i18n translation catalogues

 :deps    {org.clojure/clojure                        {:mvn/version "1.12.4"}
           cheshire/cheshire                          {:mvn/version "6.2.0"} ;; process json

           ;; Environment / Setup
           integrant/integrant                        {:mvn/version "1.0.1"}
           integrant/repl                             {:mvn/version "0.5.0"}
           environ/environ                            {:mvn/version "1.2.0"}
           aero/aero                                  {:mvn/version "1.1.6"}
           com.lambdaisland/dotenv                    {:mvn/version "0.2.5"}

           ;; HTTP Server and Routing
           ring/ring-core                             {:mvn/version "1.15.3"}
           ring/ring-jetty-adapter                    {:mvn/version "1.15.3"}
           ring/ring-anti-forgery                     {:mvn/version "1.4.0"}
           metosin/reitit-ring                        {:mvn/version "0.10.1"}
           metosin/reitit-malli                       {:mvn/version "0.10.1"}
           metosin/reitit-middleware                  {:mvn/version "0.10.1"}
           metosin/reitit-swagger                     {:mvn/version "0.10.1"}
           metosin/reitit-swagger-ui                  {:mvn/version "0.10.1"}
           metosin/muuntaja                           {:mvn/version "0.6.11"}

           ;; CLI
           org.clojure/tools.cli                      {:mvn/version "1.3.250"}

           ;; Database abstraction and connection pooling
           ;; Note: JDBC drivers are loaded conditionally via aliases based on active config
           com.github.seancorfield/next.jdbc          {:mvn/version "1.3.1093"}
           com.github.seancorfield/honeysql           {:mvn/version "2.7.1368"}
           com.zaxxer/HikariCP                        {:mvn/version "7.0.2"}
           migratus/migratus                          {:mvn/version "1.6.5"}

           ;; Schema and validation library
           metosin/malli                              {:mvn/version "0.20.1"}

           ;; logging:
           org.clojure/tools.logging                  {:mvn/version "1.3.1"}
           ch.qos.logback/logback-classic             {:mvn/version "1.5.23"}

           ;; Error reporting:
           io.sentry/sentry-clj                       {:mvn/version "8.34.247"}

           ;; Authentication and security
           buddy/buddy-hashers                        {:mvn/version "2.0.167"}
           buddy/buddy-sign                           {:mvn/version "3.6.1-359"}
           one-time/one-time                          {:mvn/version "0.8.0" ;; TOTP/HOTP for MFA
                                                       :exclusions  [com.github.kenglxn.qrgen/javase]}

           ;; Web UI and Templates
           hiccup/hiccup                              {:mvn/version "2.0.0"}

           ;; File Storage - AWS SDK for S3
           software.amazon.awssdk/s3                  {:mvn/version "2.39.5"}
           software.amazon.awssdk/s3-transfer-manager {:mvn/version "2.39.5"}

           ;; Redis client for cache and jobs libs
           redis.clients/jedis                        {:mvn/version "7.1.0"}

           ;; Email - javax.mail for SMTP
           com.sun.mail/javax.mail                    {:mvn/version "1.6.2"}

           ;; HTTP clients
           hato/hato                                  {:mvn/version "1.0.0"}
           ;; External service adapters - HTTP client for Stripe/Twilio REST APIs
           clj-http/clj-http                          {:mvn/version "3.13.1"}

           ;; Reports - PDF and Excel generation
           com.openhtmltopdf/openhtmltopdf-pdfbox     {:mvn/version "1.0.10"}
           dk.ative/docjure                           {:mvn/version "1.22.0"}

           ;; Calendar - iCal generation and parsing
           org.mnode.ical4j/ical4j                    {:mvn/version "4.1.1"}}

 :aliases {;; =============================================================================
           ;; Development and REPL aliases
           ;; =============================================================================

           :repl-clj  {:extra-paths ["dev" "dev/repl"
                                     "libs/devtools/src"]
                       :extra-deps  {nrepl/nrepl             {:mvn/version "1.6.0"}
                                     cider/cider-nrepl       {:mvn/version "0.58.0"}
                                     ring/ring-jetty-adapter {:mvn/version "1.15.3"}}
                       :main-opts   ["-m" "nrepl.cmdline" "--port" "7888" "--middleware" "[cider.nrepl/cider-middleware]"]}
           :repl-cljs {:extra-deps {org.clojure/clojurescript {:mvn/version "1.12.116"}
                                    cider/cider-nrepl         {:mvn/version "0.58.0"}
                                    cider/piggieback          {:mvn/version "0.6.1"}}
                       :main-opts  ["-m" "nrepl.cmdline" "--middleware"
                                    "[cider.nrepl/cider-middleware,cider.piggieback/wrap-cljs-repl]"]}

           ;; =============================================================================
           ;; Database JDBC drivers:
           ;; Drivers are now loaded dynamically based on active databases in config
           ;; Include all common drivers to support all possible configurations
           ;; =============================================================================

           :db        {:extra-deps {org.xerial/sqlite-jdbc      {:mvn/version "3.51.0.0"}
                                    org.postgresql/postgresql   {:mvn/version "42.7.8"}
                                    com.h2database/h2           {:mvn/version "2.4.240"}
                                    com.mysql/mysql-connector-j {:mvn/version "9.5.0"}}}

           ;; =============================================================================
           ;; Environment aliases with database support
           ;; Use :db alias to include all database drivers, actual drivers loaded by config
           ;; =============================================================================

           :dev       {:extra-paths ["dev" "dev/repl"
                                     "libs/devtools/src"]
                       :extra-deps  {org.xerial/sqlite-jdbc      {:mvn/version "3.51.0.0"}
                                     org.postgresql/postgresql   {:mvn/version "42.7.8"}
                                     com.h2database/h2           {:mvn/version "2.4.240"}
                                     com.mysql/mysql-connector-j {:mvn/version "9.5.0"}}
                       :jvm-opts    ["-Denv=dev"]}
           :prod      {:extra-deps {org.xerial/sqlite-jdbc      {:mvn/version "3.51.0.0"}
                                    org.postgresql/postgresql   {:mvn/version "42.7.8"}
                                    com.h2database/h2           {:mvn/version "2.4.240"}
                                    com.mysql/mysql-connector-j {:mvn/version "9.5.0"}}
                       :jvm-opts   ["-Denv=prod"]}

           ;; =============================================================================
           ;; Tool and utility aliases
           ;; =============================================================================

           :cljfmt    {:extra-deps {lein-cljfmt/lein-cljfmt {:mvn/version "0.9.2"}}}
           :main-opts ["-m" "cljfmt.main"]
           :docs-lint {:extra-paths ["dev"]
                       :main-opts   ["-m" "boundary.tools.docs-lint"]}
           :clj-kondo {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2026.01.19"}}
                       :main-opts    ["-m" "clj-kondo.main"]
                       :extra-paths  ["src"]}
           :test      {:main-opts   ["-m" "kaocha.runner"]
                       :extra-paths ["test" "dev"
                                     "libs/devtools/src" "libs/devtools/test"
                                     "libs/devtools/resources"]
                       :extra-deps  {lambdaisland/kaocha             {:mvn/version "1.91.1392"}
                                     org.clojure/test.check          {:mvn/version "1.1.2"}
                                     com.gfredericks/test.chuck      {:mvn/version "0.2.15"}
                                     org.xerial/sqlite-jdbc          {:mvn/version "3.51.0.0"}
                                     org.postgresql/postgresql       {:mvn/version "42.7.8"}
                                     com.h2database/h2               {:mvn/version "2.4.240"}
                                     com.mysql/mysql-connector-j     {:mvn/version "9.5.0"}
                                     org.clj-commons/clj-http-lite   {:mvn/version "1.0.13"}}
                       :jvm-opts    ["-Denv=test" "--enable-native-access=ALL-UNNAMED"]}
           :outdated  {:extra-deps {olical/depot {:mvn/version "2.4.1"}}
                       :main-opts  ["-m" "depot.outdated.main"]}
           :build     {:main-opts  ["-m" "build"]
                       :extra-deps {org.clojure/clojure           {:mvn/version "1.12.3"}
                                    io.github.clojure/tools.build {:git/tag "v0.10.11" :git/sha "c6c670a4"}}
                       :ns-default build}
           :migrate   {:main-opts  ["-m" "boundary.platform.shell.database.cli-migrations"]
                       :extra-deps {org.xerial/sqlite-jdbc      {:mvn/version "3.51.0.0"}
                                    org.postgresql/postgresql   {:mvn/version "42.7.8"}
                                    com.h2database/h2           {:mvn/version "2.4.240"}
                                    com.mysql/mysql-connector-j {:mvn/version "9.5.0"}}}
           :bench     {:extra-paths ["dev"]
                       :extra-deps  {criterium/criterium {:mvn/version "0.4.6"}}
                       :main-opts   ["-m" "boundary.bench.core"]}
           :coverage  {:extra-deps  {cloverage/cloverage         {:mvn/version "1.2.4"}
                                     org.xerial/sqlite-jdbc      {:mvn/version "3.51.0.0"}
                                     org.postgresql/postgresql   {:mvn/version "42.7.8"}
                                     com.h2database/h2           {:mvn/version "2.4.240"}
                                     com.mysql/mysql-connector-j {:mvn/version "9.5.0"}}
                       :main-opts   ["-m" "cloverage.coverage"
                                     "--src-ns-path" "src"
                                     "--src-ns-path" "libs/core/src"
                                     "--src-ns-path" "libs/observability/src"
                                     "--src-ns-path" "libs/platform/src"
                                     "--src-ns-path" "libs/user/src"
                                     "--src-ns-path" "libs/admin/src"
                                     "--src-ns-path" "libs/storage/src"
                                     "--src-ns-path" "libs/scaffolder/src"
                                     "--src-ns-path" "libs/cache/src"
                                     "--src-ns-path" "libs/jobs/src"
                                     "--src-ns-path" "libs/email/src"
                                     "--src-ns-path" "libs/tenant/src"
                                     "--src-ns-path" "libs/realtime/src"
                                     "--src-ns-path" "libs/workflow/src"
                                     "--src-ns-path" "libs/search/src"
                                     "--src-ns-path" "libs/payments/src"
                                     "--src-ns-path" "libs/external/src"
                                     "--src-ns-path" "libs/reports/src"
                                     "--src-ns-path" "libs/calendar/src"
                                     "--src-ns-path" "libs/geo/src"
                                     "--src-ns-path" "libs/ai/src"
                                     "--src-ns-path" "libs/ui-style/src"
                                     "--src-ns-path" "libs/i18n/src"
                                     "--test-ns-path" "test"
                                     "--test-ns-path" "libs/core/test"
                                     "--test-ns-path" "libs/observability/test"
                                     "--test-ns-path" "libs/platform/test"
                                     "--test-ns-path" "libs/user/test"
                                     "--test-ns-path" "libs/admin/test"
                                     "--test-ns-path" "libs/storage/test"
                                     "--test-ns-path" "libs/scaffolder/test"
                                     "--test-ns-path" "libs/cache/test"
                                     "--test-ns-path" "libs/jobs/test"
                                     "--test-ns-path" "libs/email/test"
                                     "--test-ns-path" "libs/tenant/test"
                                     "--test-ns-path" "libs/realtime/test"
                                     "--test-ns-path" "libs/workflow/test"
                                     "--test-ns-path" "libs/search/test"
                                     "--test-ns-path" "libs/payments/test"
                                     "--test-ns-path" "libs/external/test"
                                     "--test-ns-path" "libs/reports/test"
                                     "--test-ns-path" "libs/calendar/test"
                                     "--test-ns-path" "libs/geo/test"
                                     "--test-ns-path" "libs/ai/test"
                                     "--test-ns-path" "libs/ui-style/test"
                                     "--test-ns-path" "libs/i18n/test"
                                     "--no-html"
                                     "--text"]
                       :extra-paths ["test" "dev"
                                     "libs/core/src" "libs/core/test"
                                     "libs/observability/src" "libs/observability/test"
                                     "libs/platform/src" "libs/platform/test"
                                     "libs/user/src" "libs/user/test"
                                     "libs/admin/src" "libs/admin/test"
                                     "libs/storage/src" "libs/storage/test"
                                     "libs/scaffolder/src" "libs/scaffolder/test"
                                     "libs/cache/src" "libs/cache/test"
                                     "libs/jobs/src" "libs/jobs/test"
                                     "libs/email/src" "libs/email/test"
                                     "libs/tenant/src" "libs/tenant/test"
                                     "libs/realtime/src" "libs/realtime/test"
                                     "libs/workflow/src" "libs/workflow/test"
                                     "libs/search/src" "libs/search/test"
                                     "libs/payments/src" "libs/payments/test"
                                     "libs/external/src" "libs/external/test"
                                     "libs/reports/src" "libs/reports/test"
                                     "libs/calendar/src" "libs/calendar/test"
                                     "libs/geo/src" "libs/geo/test" "libs/geo/resources"
                                     "libs/ai/src" "libs/ai/test"
                                     "libs/ui-style/src" "libs/ui-style/test"
                                     "libs/i18n/src" "libs/i18n/test"]
                       :jvm-opts    ["-Denv=test" "--enable-native-access=ALL-UNNAMED"]}

           ;; =============================================================================
           ;; End-to-end test suite (spel / Playwright Java via Clojure)
           ;;
           ;; Opt-in only — activating this alias pulls in Playwright Java browser
           ;; bindings, which are large and not needed by normal :test runs.
           ;; Usage:
           ;;   clojure -M:test:e2e :e2e
           ;; or via the bb task:
           ;;   bb e2e
           ;; =============================================================================

           :e2e       {:extra-paths ["libs/e2e/src" "libs/e2e/test"]
                       :extra-deps  {com.blockether/spel {:mvn/version "0.7.11"}}}

           ;; =============================================================================
           ;; CLI Interface
           ;; =============================================================================

           :cli       {:extra-deps {org.xerial/sqlite-jdbc      {:mvn/version "3.51.0.0"}
                                    org.postgresql/postgresql   {:mvn/version "42.7.8"}
                                    com.h2database/h2           {:mvn/version "2.4.240"}
                                    com.mysql/mysql-connector-j {:mvn/version "9.5.0"}}
                       :main-opts  ["-m" "boundary.cli"]
                       :jvm-opts   ["-Denv=dev"]}

           ;; =============================================================================
           ;; HTTP server entrypoint (invokes boundary.main/-main in server mode).
           ;; Used by `bb run-e2e-server` for Playwright/spel e2e runs, and available
           ;; for any local run that needs to boot the Integrant system from deps.edn
           ;; rather than the uberjar. Respects BND_ENV to select the active profile.
           ;; =============================================================================

           :run       {:extra-deps {org.xerial/sqlite-jdbc      {:mvn/version "3.51.0.0"}
                                    org.postgresql/postgresql   {:mvn/version "42.7.8"}
                                    com.h2database/h2           {:mvn/version "2.4.240"}
                                    com.mysql/mysql-connector-j {:mvn/version "9.5.0"}}
                       :main-opts  ["-m" "boundary.main"]}

           ;; =============================================================================
           ;; Documentation
           ;; =============================================================================

           :docs      {:exec-fn   clojure.core/sh
                       :exec-args ["scripts/build-docs.sh"]}}}
