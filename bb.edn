{:paths ["scripts"]
 :tasks
 {check-links
  {:doc "Validate local markdown links in AGENTS documentation"
   :task (do (require 'check-agents-links)
             (System/exit ((resolve 'check-agents-links/-main))))}

  smoke-check
  {:doc "Run command smoke checks (verify deps.edn aliases and key commands)"
   :task (do (require 'smoke-check)
             ((resolve 'smoke-check/-main)))}

  install-hooks
  {:doc "Configure git hooks path to .githooks"
   :task (do (babashka.process/shell "git" "config" "core.hooksPath" ".githooks")
             (println "Configured git hooks path: .githooks"))}

  scaffold
  {:doc "Interactive module scaffolding wizard (bb scaffold [generate|new|field|endpoint|adapter|ai])"
   :task (do (require 'scaffold)
             (apply (resolve 'scaffold/-main) *command-line-args*))}

  ai
  {:doc "Framework-aware AI tooling (bb ai [explain|gen-tests|sql|docs])"
   :task (do (require 'ai)
             (apply (resolve 'ai/-main) *command-line-args*))}

  deploy
  {:doc "Deploy Boundary libraries to Clojars (bb deploy --help for usage)"
   :task (do (require 'deploy)
             (apply (resolve 'deploy/-main) *command-line-args*))}}}
