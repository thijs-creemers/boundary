#kaocha/v1
 {;; E2E suite is split from tests.edn so the default :test alias
  ;; does not require spel / Playwright Java on the classpath.
  :kaocha/source-paths ["src"
                        "libs/core/src"
                        "libs/observability/src"
                        "libs/platform/src"
                        "libs/user/src"
                        "libs/admin/src"
                        "libs/storage/src"
                        "libs/scaffolder/src"
                        "libs/cache/src"
                        "libs/jobs/src"
                        "libs/email/src"
                        "libs/tenant/src"
                        "libs/realtime/src"
                        "libs/payments/src"
                        "libs/external/src"
                        "libs/workflow/src"
                        "libs/search/src"
                        "libs/reports/src"
                        "libs/calendar/src"
                        "libs/geo/src"
                        "libs/ai/src"
                        "libs/ui-style/src"
                        "libs/i18n/src"
                        "libs/e2e/src"]

  :tests [{:id :e2e
           :test-paths ["libs/e2e/test"]
           :ns-patterns ["boundary.e2e.*-test"]}]

  :plugins [:kaocha.plugin/randomize
            :kaocha.plugin/filter
            :kaocha.plugin/profiling]

  :kaocha.plugin.filter/focus-meta [:unit :integration :contract :e2e :user :billing :phase3]
  :kaocha.plugin.randomize/randomize? true
  :kaocha/reporter [boundary.test.reporter/reporter]
  :kaocha/fail-fast? false
  :kaocha/color? true
  :kaocha/watch? false}
